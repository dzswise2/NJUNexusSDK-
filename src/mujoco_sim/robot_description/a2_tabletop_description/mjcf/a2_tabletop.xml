<?xml version='1.0' encoding='utf-8'?>
<mujoco model="robot_with_actuators">
  <option timestep="0.002" gravity="0 0 -9.81" />
  <visual>
    <headlight ambient="0.5 0.5 0.5" />
  </visual>
  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.1 0.2 0.3" rgb2="0.2 0.3 0.4" />
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0.2" />
  </asset>
  <include file="a2_tabletop_base.xml" />
  <worldbody>
    <light name="top" pos="0 0 2" dir="0 0 -1" directional="true" />
    <geom name="ground" type="plane" size="0 0 0.05" material="grid" condim="3" />
  </worldbody>
  <!-- 夹爪耦合约束：finger_joint2 跟随 finger_joint1 镜像运动 -->
  <equality>
    <joint name="left_gripper_coupling" joint1="left_gripper_finger_joint1" joint2="left_gripper_finger_joint2" polycoef="0 -1 0 0 0" />
  </equality>
  
  <actuator>
    <motor name="act_left_arm_joint1" joint="left_arm_joint1" gear="1" ctrlrange="-55.0 55.0" forcerange="-55.0 55.0" />
    <motor name="act_left_arm_joint2" joint="left_arm_joint2" gear="1" ctrlrange="-55.0 55.0" forcerange="-55.0 55.0" />
    <motor name="act_left_arm_joint3" joint="left_arm_joint3" gear="1" ctrlrange="-25.0 25.0" forcerange="-25.0 25.0" />
    <motor name="act_left_arm_joint4" joint="left_arm_joint4" gear="1" ctrlrange="-25.0 25.0" forcerange="-25.0 25.0" />
    <motor name="act_left_arm_joint5" joint="left_arm_joint5" gear="1" ctrlrange="-18.0 18.0" forcerange="-18.0 18.0" />
    <motor name="act_left_arm_joint6" joint="left_arm_joint6" gear="1" ctrlrange="-18.0 18.0" forcerange="-18.0 18.0" />
    <motor name="act_left_arm_joint7" joint="left_arm_joint7" gear="1" ctrlrange="-18.0 18.0" forcerange="-18.0 18.0" />
    <!-- 夹爪：只控制 finger_joint1，finger_joint2 通过 equality 约束自动跟随 -->
    <motor name="act_left_gripper" joint="left_gripper_finger_joint1" gear="1" ctrlrange="-100.0 100.0" forcerange="-100.0 100.0" />
  </actuator>
</mujoco>
